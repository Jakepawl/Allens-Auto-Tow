---
import PageLayout from '~/layouts/PageLayout.astro';
import ContactForm from '~/components/islands/ContactForm';
import { business } from '~/utils/business-info';
import { Icon } from 'astro-icon/components';

const metadata = {
  title: "Contact Us",
  description: `Contact Allen's Automotive & Towing in Livermore, CA. Call ${business.phone.repair} for repairs or ${business.phone.towing} for 24/7 towing.`,
};
---

<PageLayout metadata={metadata} breadcrumbs={[{ label: 'Contact', href: '/contact' }]}>
  <h1 class="text-3xl font-bold text-gray-900 mb-8" style="font-family: var(--font-heading)">Contact Us</h1>
  <div class="grid lg:grid-cols-2 gap-12">
    <div>
      <h2 class="text-xl font-semibold text-gray-900 mb-4" style="font-family: var(--font-heading)">Send Us a Message</h2>
      <ContactForm client:visible />
    </div>
    <div class="space-y-6">
      <div class="bg-gray-50 rounded-lg p-6 space-y-4">
        <div class="flex items-start gap-3">
          <Icon name="tabler:map-pin" class="w-5 h-5 text-[var(--color-primary)] mt-0.5" />
          <div>
            <div class="font-medium text-gray-900">Address</div>
            <a href={business.social.googleMaps} target="_blank" rel="noopener" class="text-sm text-gray-600 hover:text-[var(--color-primary)]">{business.address.full}</a>
          </div>
        </div>
        <div class="flex items-start gap-3">
          <Icon name="tabler:phone" class="w-5 h-5 text-[var(--color-primary)] mt-0.5" />
          <div>
            <div class="font-medium text-gray-900">Phone</div>
            <div class="text-sm text-gray-600">Repair: <a href={`tel:${business.phone.repairTel}`} class="hover:text-[var(--color-primary)]">{business.phone.repair}</a></div>
            <div class="text-sm text-gray-600">Towing: <a href={`tel:${business.phone.towingTel}`} class="hover:text-[var(--color-primary)]">{business.phone.towing}</a></div>
          </div>
        </div>
        <div class="flex items-start gap-3">
          <Icon name="tabler:clock" class="w-5 h-5 text-[var(--color-primary)] mt-0.5" />
          <div>
            <div class="font-medium text-gray-900">Hours</div>
            <div class="text-sm text-gray-600">{business.hours.repair}</div>
            <div class="text-sm font-medium" style="color: var(--color-success)">Towing: {business.hours.towing}</div>
          </div>
        </div>
      </div>
      <div class="rounded-lg overflow-hidden border bg-gray-100" style="aspect-ratio: 16/9">
        <iframe
          src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d3158.5!2d-121.7715236!3d37.6837567!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x0%3A0x0!2zMzfCsDQxJzAxLjUiTiAxMjHCsDQ2JzE3LjUiVw!5e0!3m2!1sen!2sus!4v1234567890"
          width="100%" height="100%" style="border:0; min-height:250px" allowfullscreen loading="lazy"
          referrerpolicy="no-referrer-when-downgrade" title="Allen's Automotive & Towing location map">
        </iframe>
      </div>
    </div>
  </div>
</PageLayout>
