---
import { mainNav } from '~/navigation';
import { business } from '~/utils/business-info';
import { Icon } from 'astro-icon/components';
---

<header class="sticky top-0 z-50 bg-white shadow-sm">
  <!-- Top bar: phone numbers and hours -->
  <div class="bg-[#0F172A] text-white text-sm py-1.5">
    <div class="max-w-7xl mx-auto px-4 flex justify-between items-center">
      <span class="flex items-center gap-1.5">
        <Icon name="tabler:phone" class="w-4 h-4" />
        Repair: <a href={`tel:${business.phone.repairTel}`} class="font-semibold hover:underline">{business.phone.repair}</a>
      </span>
      <span class="hidden sm:flex items-center gap-1.5">
        <Icon name="tabler:truck" class="w-4 h-4" />
        24/7 Towing: <a href={`tel:${business.phone.towingTel}`} class="font-semibold hover:underline">{business.phone.towing}</a>
      </span>
      <span class="hidden md:flex items-center gap-1.5">
        <Icon name="tabler:clock" class="w-4 h-4" />
        {business.hours.repair}
      </span>
    </div>
  </div>

  <!-- Main nav bar -->
  <nav class="max-w-7xl mx-auto px-4 py-3 flex items-center justify-between">
    <!-- Logo / brand -->
    <a href="/" class="flex items-center gap-2" aria-label={business.name}>
      <div class="w-10 h-10 bg-blue-700 rounded-full flex items-center justify-center text-white font-bold text-lg">A</div>
      <div class="hidden sm:block">
        <div class="font-bold text-lg text-gray-900 leading-tight">Allen's Automotive</div>
        <div class="text-xs text-gray-500">& Towing Inc</div>
      </div>
    </a>

    <!-- Desktop nav links -->
    <ul class="hidden lg:flex items-center gap-6">
      {mainNav.map((item) => (
        <li class="relative group">
          <a href={item.href} class="text-gray-700 hover:text-blue-700 font-medium text-sm transition-colors py-2">
            {item.label}
            {item.children && <Icon name="tabler:chevron-down" class="w-3.5 h-3.5 inline ml-0.5" />}
          </a>
          {item.children && (
            <ul class="absolute top-full left-0 mt-1 bg-white shadow-lg rounded-md py-2 min-w-48 opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-200 z-50">
              {item.children.map((child) => (
                <li>
                  <a href={child.href} class="block px-4 py-2 text-sm text-gray-700 hover:bg-blue-50 hover:text-blue-700">{child.label}</a>
                </li>
              ))}
            </ul>
          )}
        </li>
      ))}
    </ul>

    <!-- CTA buttons + mobile menu toggle -->
    <div class="flex items-center gap-3">
      <a
        href="/appointment"
        class="hidden sm:inline-flex items-center gap-1.5 bg-[var(--color-cta)] text-white px-4 py-2 rounded-md text-sm font-semibold hover:bg-[var(--color-cta-hover)] transition-colors"
      >
        <Icon name="tabler:calendar" class="w-4 h-4" />
        Book Appointment
      </a>
      <a
        href={`tel:${business.phone.repairTel}`}
        class="sm:hidden inline-flex items-center gap-1.5 bg-[var(--color-cta)] text-white px-3 py-2 rounded-md text-sm font-semibold hover:bg-[var(--color-cta-hover)] transition-colors"
        aria-label="Tap to call"
      >
        <Icon name="tabler:phone" class="w-4 h-4" />
        Call Now
      </a>
      <button
        id="mobile-menu-toggle"
        class="lg:hidden p-2 text-gray-700 hover:text-blue-700"
        aria-label="Toggle menu"
        aria-expanded="false"
      >
        <Icon name="tabler:menu-2" class="w-6 h-6" />
      </button>
    </div>
  </nav>

  <!-- Mobile menu (hidden by default) -->
  <div id="mobile-menu" class="hidden lg:hidden bg-white border-t">
    <ul class="max-w-7xl mx-auto px-4 py-4 space-y-2">
      {mainNav.map((item) => (
        <li>
          <a href={item.href} class="block py-2 text-gray-700 font-medium hover:text-blue-700">{item.label}</a>
          {item.children && (
            <ul class="pl-4 space-y-1">
              {item.children.map((child) => (
                <li><a href={child.href} class="block py-1.5 text-sm text-gray-500 hover:text-blue-700">{child.label}</a></li>
              ))}
            </ul>
          )}
        </li>
      ))}
    </ul>
  </div>
</header>

<script>
  // Toggle mobile menu open/closed and update aria-expanded accordingly
  const toggle = document.getElementById('mobile-menu-toggle');
  const menu = document.getElementById('mobile-menu');
  if (toggle && menu) {
    toggle.addEventListener('click', () => {
      const expanded = toggle.getAttribute('aria-expanded') === 'true';
      toggle.setAttribute('aria-expanded', String(!expanded));
      menu.classList.toggle('hidden');
    });
  }
</script>
