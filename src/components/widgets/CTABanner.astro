---
import { business } from '~/utils/business-info';
import { Icon } from 'astro-icon/components';

interface Props {
  headline?: string;
  subtext?: string;
}

const {
  headline = 'Need Auto Repair or Towing?',
  subtext = "Schedule an appointment or call us now. Same-day service available on most repairs.",
} = Astro.props;
---

<section class="bg-[var(--color-primary)] text-white py-12">
  <div class="max-w-7xl mx-auto px-4 text-center" data-animate>
    <h2 class="text-2xl md:text-3xl font-bold mb-3">{headline}</h2>
    <p class="text-blue-100 mb-6 max-w-xl mx-auto">{subtext}</p>
    <div class="flex flex-wrap justify-center gap-3">
      <a href="/appointment" class="inline-flex items-center gap-2 bg-[var(--color-cta)] text-white px-6 py-3 rounded-md font-bold hover:bg-[var(--color-cta-hover)] transition-colors">
        <Icon name="tabler:calendar" class="w-5 h-5" />
        Book Appointment
      </a>
      <a href={`tel:${business.phone.repairTel}`} class="inline-flex items-center gap-2 border-2 border-white text-white px-6 py-3 rounded-md font-bold hover:bg-white/10 transition-colors">
        <Icon name="tabler:phone" class="w-5 h-5" />
        {business.phone.repair}
      </a>
    </div>
  </div>
</section>
