---
import { business } from '~/utils/business-info';
import { Icon } from 'astro-icon/components';
---

<section class="relative bg-[#0F172A] text-white overflow-hidden">
  <div class="max-w-7xl mx-auto px-4 py-16 md:py-24 grid md:grid-cols-2 gap-8 items-center">
    <div data-animate style="transition-delay: 100ms">
      <p class="text-blue-200 text-sm font-semibold uppercase tracking-wider mb-2">
        Serving Livermore Since {business.foundingYear}
      </p>
      <h1 class="text-4xl md:text-5xl font-bold leading-tight mb-4">
        Honest Auto Repair &amp; 24/7 Towing
      </h1>
      <p class="text-blue-100 text-lg mb-8 max-w-lg">
        ASE-certified mechanics, same-day service on most repairs, and transparent pricing. Your trusted neighborhood auto shop for over 40 years.
      </p>
      <div class="flex flex-wrap gap-3">
        <a href="/appointment" class="inline-flex items-center gap-2 bg-[var(--color-cta)] text-white px-6 py-3 rounded-md font-bold hover:bg-[var(--color-cta-hover)] transition-colors">
          <Icon name="tabler:calendar" class="w-5 h-5" />
          Schedule Service
        </a>
        <a href={`tel:${business.phone.repairTel}`} class="inline-flex items-center gap-2 border-2 border-white text-white px-6 py-3 rounded-md font-bold hover:bg-white/10 transition-colors">
          <Icon name="tabler:phone" class="w-5 h-5" />
          Call {business.phone.repair}
        </a>
      </div>
    </div>
    <div class="hidden md:block" data-animate="fade-right" style="transition-delay: 200ms">
      <div class="bg-blue-800/50 rounded-lg p-12 text-center text-blue-300">
        <Icon name="tabler:car" class="w-24 h-24 mx-auto mb-4" />
        <p class="text-sm">Hero image placeholder</p>
      </div>
    </div>
  </div>
</section>
